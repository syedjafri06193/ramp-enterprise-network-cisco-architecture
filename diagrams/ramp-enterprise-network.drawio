<mxfile host="app.diagrams.net">
  <diagram name="Ramp Enterprise Network">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="edge" value="EDGE1&#10;Internet Edge&#10;(NAT/PAT)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="40" width="180" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="dist1" value="DIST1&#10;Distribution (L3)&#10;HSRP + STP Root" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="180" width="240" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="dist2" value="DIST2&#10;Distribution (L3)&#10;HSRP + STP Secondary" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="180" width="260" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="acc1" value="ACCESS1&#10;Access Switch" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="340" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="acc2" value="ACCESS2&#10;Access Switch" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="340" width="220" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="vlanbox" value="Segments (VLANs)&#10;10 HR&#10;20 Finance&#10;30 Engineering&#10;40 Guest&#10;99 Mgmt" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="470" width="260" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="e1" style="endArrow=classic;html=1;" edge="1" parent="1" source="edge" target="dist1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;" edge="1" parent="1" source="edge" target="dist2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;" edge="1" parent="1" source="dist1" target="acc1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" style="endArrow=classic;html=1;" edge="1" parent="1" source="dist1" target="acc2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" style="endArrow=classic;html=1;" edge="1" parent="1" source="dist2" target="acc1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" style="endArrow=classic;html=1;" edge="1" parent="1" source="dist2" target="acc2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
